# === Claude Code / Laravel Boost ===
# Auto-generated by `php artisan boost:install` — regenerated, don't commit
CLAUDE.md
AGENTS.md

# Machine-specific Claude Code settings (per-developer overrides)
.claude/settings.local.json

# .claude/skills/ is regenerated by `boost:install` on every composer run:
# - vendor skills (pest-testing, etc.) are copied from vendor/laravel/boost
# - our own skills (.ai/skills/<name>) get symlinked in via Boost
# Tracking them adds noise and cross-platform symlink risk.
.claude/skills/

# Learnings — inbox and state are private; archive is committed
.ai/learnings/inbox.md
.ai/learnings/inbox-*.md
.ai/learnings/.last-reminder

# Agent runtime artifacts (worker workspace)
.agent/
:memory:

# Local scratch notes
todo.md
docs/BACKLOG.md
docs/backlog/

# Stage secrets (never commit)
.tools/bash/.env.stage
