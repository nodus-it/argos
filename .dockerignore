# Bootstrap cache — wird im Image neu generiert (composer post-autoload-dump)
bootstrap/cache/*.php

# Node & build artefacts
node_modules/
public/build/
public/hot

# Dev/test assets
.env
.env.*
!.env.example
storage/logs/*.log
# Ephemeral test scratch dirs — never belong in the image build context and
# may be root-owned (created by tests running in containers), which breaks the
# build context tar on local builds.
storage/framework/testing/

# CI / VCS
.git/
.github/

# Dev tools
.phpunit.cache/
.phpunit.result.cache
todo.md
