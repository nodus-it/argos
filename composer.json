{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": "^8.3",
        "dedoc/scramble": "^0.13.26",
        "dutchcodingcompany/filament-developer-logins": "^2.1",
        "filament/filament": "^5.0",
        "laravel/framework": "^13.0",
        "laravel/horizon": "^5.46",
        "laravel/passport": "^13",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.27",
        "laravel/tinker": "^3.0",
        "predis/predis": "^3.4",
        "saloonphp/laravel-plugin": "^4.3",
        "saloonphp/pagination-plugin": "^2.3",
        "saloonphp/saloon": "^4.0",
        "socialiteproviders/bitbucket": "^4.1",
        "socialiteproviders/gitlab": "^4.1",
        "spatie/laravel-medialibrary": "^11.23",
        "symfony/process": "^8.0",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/boost": "^2.4",
        "laravel/pail": "^1.2.5",
        "laravel/pao": "^1.0.6",
        "mockery/mockery": "^1.6",
        "nodus-it/dev-tools": "dev-main",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],

        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#fb7185\" \"docker compose --env-file .env -f .tools/docker/docker-compose.yml -f .tools/docker/docker-compose.dev.yml -f .tools/docker/docker-compose.proxy.yml up --build --remove-orphans\" \"npm run dev\" --names=compose,vite --kill-others"
        ],
        "dev:port": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#fb7185\" \"docker compose --env-file .env -f .tools/docker/docker-compose.yml -f .tools/docker/docker-compose.dev.yml up --build --remove-orphans\" \"npm run dev\" --names=compose,vite --kill-others"
        ],
        "dev:basic": "bash .tools/bin/dev-reset.sh basic",
        "dev:full": "bash .tools/bin/dev-reset.sh full",
        "dev:live": "bash .tools/bin/dev-reset.sh live",

        "test:external": "@php artisan test --compact --configuration=phpunit.external.xml",
        "test:browser:up": "bash .tools/bin/e2e-up.sh",
        "test:browser": "npx playwright test",
        "test:browser:real": "npx playwright test full-flow.real",

        "qa:full": [
            "@qa",
            "@test:external"
        ],

        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-install-cmd": [
            "@php -r \"is_dir('vendor/laravel/boost') && passthru('php artisan boost:install --no-interaction --quiet');\""
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php -r \"is_dir('vendor/laravel/boost') && passthru('php artisan boost:update --ansi --no-interaction');\""
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "nodus-dev": {
            "dir": ".tools/docker",
            "environments": {
                "dev": ["docker-compose.yml", "docker-compose.dev.yml"]
            }
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "nodus-it/dev-tools": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
