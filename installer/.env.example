# Argos installer — environment template.
#
# `install.sh` copies this file to `.env` on first install, generates the
# secret values (APP_KEY, ADMIN_PASSWORD, ARGOS_DB_*_PASSWORD) and leaves
# the rest at their defaults. On update the script merges any NEW keys
# from this file into your `.env` without touching existing values.
#
# Edit `.env` (not this file) to change settings, then `docker compose up -d`.

# ── Public access ───────────────────────────────────────────────────────────
# Host port the nginx container listens on. Map to your reverse proxy here.
ARGOS_PORT=8080

# Public URL used for OAuth callbacks and for links in emails. Defaults to
# http://localhost:${ARGOS_PORT} if unset.
APP_URL=

# ── Application ─────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false

# Laravel encryption key — generated by the installer on first run. Keep this
# stable across restarts; rotating it invalidates all encrypted data.
APP_KEY=

# Initial admin password — generated by the installer. Change it after first
# login under Profile.
ADMIN_PASSWORD=

# Pre-seed your Claude Code OAuth token here to skip the in-app onboarding.
# Generate with `claude setup-token`. Leave blank to enter via the UI.
CLAUDE_CODE_OAUTH_TOKEN=

# ── Image tags ──────────────────────────────────────────────────────────────
# Released versions of this file ship with version-pinned tags
# (e.g. argos-app:0.2.0 + argos-worker:php8.4-0.2.0) so the image:tag pair
# can't drift after install. The release workflow rewrites the values below
# on the master commit that the tag points at. On develop they stay at
# :latest / :php8.4 so `install.sh --version develop` tracks the rolling
# tags. Override only if you know what you're doing (e.g. testing :stage).
ARGOS_APP_IMAGE=ghcr.io/nodus-it/argos-app:latest
ARGOS_WORKER_IMAGE=ghcr.io/nodus-it/argos-worker:php8.4

# ── Database ────────────────────────────────────────────────────────────────
# Username and database name are safe defaults. Passwords are generated by
# the installer and persisted here — back this file up or you'll be locked
# out of your data.
ARGOS_DB_DATABASE=argos
ARGOS_DB_USERNAME=argos
ARGOS_DB_PASSWORD=
ARGOS_DB_ROOT_PASSWORD=
