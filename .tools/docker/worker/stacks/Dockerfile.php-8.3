# syntax=docker/dockerfile:1.7
#
# stacks/Dockerfile.php-8.3 — Argos worker stack: PHP 8.3 + common tools.
#
# This is a *stack* image: language runtime + common tools + non-root user.
# Agent installation (claude-code, codex, ...) happens in Dockerfile.compose
# as a later layer; worker code is also added there. The result is reusable
# across agents — `argos-worker:php-8.3-claude-code`,
# `argos-worker:php-8.3-codex`, etc. all share this stack image.
FROM php:8.3-cli-bookworm

ENV DEBIAN_FRONTEND=noninteractive

# Common tools used by every Argos worker, regardless of agent:
#   git/gh        — repo operations + PR creation
#   jq            — JSON parsing in phase scripts
#   curl/gnupg    — PECL/GH-CLI installation, runtime HTTP
#   unzip/coreutils/vim/nano/less — interactive `agent shell` ergonomics
#   PHP build deps (libzip-dev, libicu-dev, ...) — needed for the extensions below.
RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        gnupg \
        git \
        unzip \
        jq \
        coreutils \
        vim \
        nano \
        less \
        libzip-dev \
        libicu-dev \
        libpng-dev \
        libfreetype6-dev \
        libjpeg-dev \
        libonig-dev \
        libxml2-dev \
        libsqlite3-dev \
        libpq-dev \
        zlib1g-dev; \
    install -m 0755 -d /etc/apt/keyrings; \
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        -o /etc/apt/keyrings/githubcli-archive-keyring.gpg; \
    chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg; \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list; \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash -; \
    apt-get update; \
    apt-get install -y --no-install-recommends gh nodejs; \
    rm -rf /var/lib/apt/lists/*

# PHP extensions: Laravel-Standard + Redis (PECL).
# mbstring, sodium and OPcache ship with the php:8.x base image already.
# pcntl  — Horizon, queue workers, Pail.
# exif   — spatie/image, spatie/laravel-medialibrary.
# pdo_pgsql — Postgres-backed projects (needs libpq-dev, installed above).
RUN set -eux; \
    docker-php-ext-configure intl; \
    docker-php-ext-configure gd --with-freetype --with-jpeg; \
    docker-php-ext-install -j"$(nproc)" \
        intl \
        pdo_mysql \
        pdo_sqlite \
        pdo_pgsql \
        zip \
        bcmath \
        gd \
        pcntl \
        exif; \
    pecl install redis; \
    docker-php-ext-enable redis

# Composer (latest stable) from the official image.
COPY --from=composer:latest /usr/bin/composer /usr/local/bin/composer

# Non-root user `agent` (UID 1000) — phase scripts run under this user.
RUN useradd --create-home --shell /bin/bash --uid 1000 agent
