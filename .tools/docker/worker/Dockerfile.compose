# syntax=docker/dockerfile:1.7
#
# Dockerfile.compose — final worker image = stack + agent + worker code.
#
# Built by the manager's WorkerImageResolver at task spawn (or on demand
# from the Filament UI) once a (stack, agent) pair is needed. The two
# build args wire the prior layers in:
#
#   STACK_IMAGE             pre-built stack image tag (e.g. argos-stack:php-8.4)
#                           — produced from .tools/docker/worker/stacks/Dockerfile.<name>
#                             or from a user-supplied BYOI dockerfile
#   AGENT_INSTALL_SCRIPT    path (relative to repo root) to the agent install script
#                           — e.g. .tools/docker/worker/agents/install-claude-code.sh
#   AGENT_VERSION           optional npm version to pin the agent CLI (defaults: latest)
#
# Build context is the repository root, so worker/ paths resolve cleanly.
ARG STACK_IMAGE
ARG AGENT_INSTALL_SCRIPT
ARG AGENT_VERSION=latest

FROM ${STACK_IMAGE}

# Agent layer ─ install script runs in its own RUN to keep the layer cache
# orthogonal from the stack layer beneath. A change in agent version only
# invalidates this single layer.
ARG AGENT_INSTALL_SCRIPT
ARG AGENT_VERSION
COPY ${AGENT_INSTALL_SCRIPT} /tmp/install-agent.sh
RUN AGENT_VERSION="${AGENT_VERSION}" bash /tmp/install-agent.sh \
    && rm -f /tmp/install-agent.sh

# Worker code ─ phase scripts, libs, prompts, schemas. Static; only changes
# when we ship a new Argos version, so cached aggressively.
COPY worker/lib/      /usr/local/share/agent/lib/
COPY worker/phases/   /usr/local/share/agent/phases/
COPY worker/prompts/  /usr/local/share/agent/prompts/
COPY worker/schemas/  /usr/local/share/agent/schemas/
COPY .tools/docker/worker/worker-entrypoint.sh /usr/local/bin/worker-entrypoint.sh

RUN chmod +x /usr/local/bin/worker-entrypoint.sh \
    && chown -R agent:agent /usr/local/share/agent \
    && mkdir -p /workspace \
    && chown agent:agent /workspace \
    && mkdir -p /run/agent \
    && chown agent:agent /run/agent \
    && mkdir -p /home/agent/.npm /home/agent/.composer/cache \
    && chown -R agent:agent /home/agent/.npm /home/agent/.composer

USER agent
# safe.directory: clones happen as `agent` into bind-mounted /workspace, where
# the host UID may differ from the container's — git would otherwise refuse.
# http.postBuffer + http.version: workaround for the GnuTLS-linked Debian git
# dropping the sideband stream on large pack files (curl 56 / GnuTLS -110)
# behind some reverse proxies. 500 MiB postBuffer forces a single request,
# HTTP/1.1 dodges proxies with broken HTTP/2 sideband handling.
RUN git config --global --add safe.directory '*' \
    && git config --global http.postBuffer 524288000 \
    && git config --global http.version HTTP/1.1

WORKDIR /workspace

ENTRYPOINT ["/usr/local/bin/worker-entrypoint.sh"]
CMD []
