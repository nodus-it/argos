# Argos installer — environment template.
#
# `install.sh` copies this file to `.env` on first install, generates the
# secret values (APP_KEY, ADMIN_PASSWORD, ARGOS_DB_*_PASSWORD) and leaves
# the rest at their defaults. On update the script merges any NEW keys
# from this file into your `.env` without touching existing values.
#
# Edit `.env` (not this file) to change settings, then `docker compose up -d`.

# ── Public access ───────────────────────────────────────────────────────────
# Host port the nginx container listens on. Map to your reverse proxy here.
ARGOS_PORT=8080

# Public URL used for OAuth callbacks and for links in emails. Defaults to
# http://localhost:${ARGOS_PORT} if unset.
APP_URL=

# ── Application ─────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false

# Laravel encryption key — generated by the installer on first run. Keep this
# stable across restarts; rotating it invalidates all encrypted data.
APP_KEY=

# Initial admin password — generated by the installer. Change it after first
# login under Profile.
ADMIN_PASSWORD=

# Pre-seed your Claude Code OAuth token here to skip the in-app onboarding.
# Generate with `claude setup-token`. Leave blank to enter via the UI.
CLAUDE_CODE_OAUTH_TOKEN=

# ── Git provider OAuth (required for "Connected Accounts" connect flow) ─────
# Without these the Connect buttons in the UI stay hidden because Argos has
# no way to start the OAuth handshake. Set the pair for each provider you
# want to enable, then restart the stack (`docker compose up -d`) — env vars
# are injected at container start, so a hot edit of .env alone is not enough.
#
# GitHub OAuth App → https://github.com/settings/developers
# Authorization callback URL: <APP_URL>/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitLab OAuth App → User Settings → Applications (or self-hosted equivalent)
# Redirect URI: <APP_URL>/auth/gitlab/callback
# GITLAB_INSTANCE_URL only needed for self-hosted GitLab; defaults to gitlab.com.
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_INSTANCE_URL=

# Bitbucket OAuth Consumer → Workspace settings → OAuth consumers
# Callback URL: <APP_URL>/auth/bitbucket/callback
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=

# ── Image tags ──────────────────────────────────────────────────────────────
# Released versions of this file ship with a version-pinned app image tag
# (e.g. argos-app:0.2.0) so the tag can't drift after install. The release
# workflow rewrites the value below on the master commit that the tag points
# at. On develop it stays at :latest so `install.sh --version develop`
# tracks the rolling tag. Worker images are built on demand by the manager
# from the `worker_stacks` rows — there is no separate worker image tag.
ARGOS_APP_IMAGE=ghcr.io/nodus-it/argos-app:latest

# ── Database ────────────────────────────────────────────────────────────────
# Username and database name are safe defaults. Passwords are generated by
# the installer and persisted here — back this file up or you'll be locked
# out of your data.
ARGOS_DB_DATABASE=argos
ARGOS_DB_USERNAME=argos
ARGOS_DB_PASSWORD=
ARGOS_DB_ROOT_PASSWORD=

# ── Queue ───────────────────────────────────────────────────────────────────
# Number of Horizon worker processes per queue.
# `default` handles general background jobs (image builds, refresh tasks).
# `tasks` handles long-running phase runs (RunPhaseJob).
ARGOS_QUEUE_DEFAULT_PROCESSES=5
ARGOS_QUEUE_TASKS_PROCESSES=2

# ── Live-Demo / Preview (P6) ──────────────────────────────────────────────
  # Ephemeral per-task demo deployments, routed by Traefik under their own
  # subdomain. Off by default. For a real deployment set a wildcard domain
  # (demo-<task>.<base_domain> must resolve to this host), scheme=https and
  # ARGOS_PORT=443.
  ARGOS_PREVIEW_ENABLED=false
  ARGOS_PREVIEW_BASE_DOMAIN=127.0.0.1.nip.io
  ARGOS_PREVIEW_SCHEME=http
  ARGOS_PREVIEW_TTL_HOURS=24
  ARGOS_PREVIEW_NETWORK=argos_edge
  ARGOS_PREVIEW_MAX_CONCURRENT=10
  ARGOS_PREVIEW_CPU_LIMIT=1.0
  ARGOS_PREVIEW_MEM_LIMIT=1g
  ARGOS_PREVIEW_DEFAULT_IMAGE=argos-demo
