#!/usr/bin/env bash
# agent — Claude Worker CLI auf dem Host.
#
# Subcommands:
#   init                                   Setup von 0 (Image + Token)
#   task new|list|show|delete <task-id>    Task-Lifecycle
#   concept|implement|diff|push <task-id>  Phasen
#   show-concept|edit-concept              Konzept lesen/editieren
#   show-notes|edit-notes                  Notes lesen/editieren
#   logs <task-id>                         Phase-Logs
#   shell <task-id>                        bash im Worker, Volume gemountet
#   status [<task-id>]                     Phase-Status
#   abort <task-id>                        Volume + Host-State entfernen
#   prune                                  verwaiste Volumes interaktiv aufraeumen
#
# Konventionen siehe CLAUDE.md.

set -euo pipefail
IFS=$'\n\t'

# Repo-Root finden (Verzeichnis dieses Skripts)
AGENT_REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export AGENT_REPO_ROOT

# Lib-Files sourcen
# shellcheck source=worker/lib/logging.sh
source "$AGENT_REPO_ROOT/worker/lib/logging.sh"
# shellcheck source=worker/lib/error.sh
source "$AGENT_REPO_ROOT/worker/lib/error.sh"
# shellcheck source=worker/lib/credentials.sh
source "$AGENT_REPO_ROOT/worker/lib/credentials.sh"
# shellcheck source=worker/lib/tasks.sh
source "$AGENT_REPO_ROOT/worker/lib/tasks.sh"
# shellcheck source=worker/lib/docker.sh
source "$AGENT_REPO_ROOT/worker/lib/docker.sh"
# shellcheck source=worker/lib/parse_args.sh
source "$AGENT_REPO_ROOT/worker/lib/parse_args.sh"
# shellcheck source=worker/lib/help.sh
source "$AGENT_REPO_ROOT/worker/lib/help.sh"

# ============================================================
# Helper
# ============================================================

# _agent_require_task_id: Bricht ab wenn ARG_TASK_ID leer ist.
_agent_require_task_id() {
    if [[ -z "$ARG_TASK_ID" ]]; then
        die "$EXIT_PRECONDITION" "task-id fehlt"
    fi
}

# _agent_require_known_task: Bricht ab wenn keine credentials.env existiert.
_agent_require_known_task() {
    if ! credentials_task_exists "$ARG_TASK_ID"; then
        die "$EXIT_PRECONDITION" "Task '$ARG_TASK_ID' nicht bekannt (siehe agent task list)"
    fi
}

# _agent_load_task_env: Lädt credentials + Claude-Token in die Shell.
_agent_load_task_env() {
    local task_id="$1"
    if ! credentials_load_task "$task_id"; then
        die "$EXIT_PRECONDITION" "credentials.env fuer '$task_id' fehlt"
    fi
    if ! credentials_has_claude_token; then
        die "$EXIT_AUTH" "Claude-Token fehlt unter $CLAUDE_TOKEN_FILE — bitte 'agent init' oder 'agent init --update-token'"
    fi
    CLAUDE_CODE_OAUTH_TOKEN="$(credentials_load_claude_token)"
    export REPO_URL REPO_TOKEN BASE_BRANCH CLAUDE_CODE_OAUTH_TOKEN
}

# _agent_phase_flags_json: Baut PHASE_FLAGS JSON aus den ARG_FLAG_* Variablen.
# Args: $@ = liste der Flag-Namen (lowercase), z.B. fresh continue stat file
# Output: JSON-String, z.B. {"fresh":true,"max_turns":80}
_agent_phase_flags_json() {
    local out='{}'
    local flag_name var_name val
    for flag_name in "$@"; do
        local upper
        upper="$(echo "$flag_name" | tr 'a-z-' 'A-Z_')"
        var_name="ARG_FLAG_$upper"
        val="${!var_name:-}"
        if [[ -n "$val" ]]; then
            local key
            key="$(echo "$flag_name" | tr '-' '_')"
            if [[ "$val" == "true" || "$val" == "false" ]]; then
                out="$(echo "$out" | jq --arg k "$key" --argjson v "$val" '. + {($k): $v}')"
            else
                # Versuche Zahl, sonst String
                if [[ "$val" =~ ^-?[0-9]+$ ]]; then
                    out="$(echo "$out" | jq --arg k "$key" --argjson v "$val" '. + {($k): $v}')"
                else
                    out="$(echo "$out" | jq --arg k "$key" --arg v "$val" '. + {($k): $v}')"
                fi
            fi
        fi
    done
    printf '%s' "$out"
}

# _agent_run_volume_cmd: Führt einen ad-hoc command im worker-Image mit gemountetem Task-Volume.
# Args: $1=task_id, $2..=command
_agent_run_volume_cmd() {
    local task_id="$1"; shift
    local volume
    volume="$(task_volume_name "$task_id")"
    docker run --rm \
        -v "$volume:/workspace" \
        --entrypoint sh \
        agent-worker:latest -c "$*"
}

# ============================================================
# init
# ============================================================

cmd_init() {
    local update_only="${ARG_FLAG_UPDATE_TOKEN:-}"

    # Prüfe Host-Abhängigkeit: jq wird für die Flag-Verarbeitung jeder Phase benötigt.
    if ! command -v jq &>/dev/null; then
        printf '[WARN] jq ist nicht installiert — wird für Phase-Flags benötigt.\n'
        printf '       Auf Debian/Ubuntu/WSL: sudo apt-get install -y jq\n'
        printf 'Jetzt installieren? [y/N] '
        local jq_ans
        IFS= read -r jq_ans || jq_ans="n"
        if [[ "$jq_ans" =~ ^[YyJj]$ ]]; then
            sudo apt-get install -y jq || die "$EXIT_GENERAL" "jq-Installation fehlgeschlagen — bitte manuell installieren"
        else
            printf '[WARN] Fortfahren ohne jq — Phasen-Flags (z.B. --fresh) werden nicht übergeben.\n'
        fi
    fi

    if [[ "$update_only" != "true" ]]; then
        log_info "init: baue worker-Image (kann ein paar Minuten dauern)"
        (cd "$AGENT_REPO_ROOT" && docker compose build worker)
    fi

    if credentials_has_claude_token && [[ "$update_only" != "true" ]]; then
        log_info "init: Claude-Token bereits vorhanden ($CLAUDE_TOKEN_FILE) — übersprungen. Mit --update-token erzwingen."
    else
        printf 'Claude-OAuth-Token (Eingabe versteckt; via "claude setup-token" erzeugt): '
        local token
        IFS= read -rs token
        printf '\n'
        if [[ -z "$token" ]]; then
            die "$EXIT_GENERAL" "Token darf nicht leer sein"
        fi
        printf '%s' "$token" | credentials_save_claude_token
        log_info "init: Claude-Token gespeichert in $CLAUDE_TOKEN_FILE (mode 600)"
    fi

    if [[ "$update_only" != "true" ]]; then
        printf 'Symlink ~/.local/bin/agent -> %s/agent anlegen? [y/N] ' "$AGENT_REPO_ROOT"
        local ans
        IFS= read -r ans || ans="n"
        if [[ "$ans" =~ ^[YyJj]$ ]]; then
            mkdir -p "$HOME/.local/bin"
            ln -sf "$AGENT_REPO_ROOT/agent" "$HOME/.local/bin/agent"
            log_info "init: Symlink angelegt — sicherstellen dass ~/.local/bin im PATH ist"
        fi
    fi

    log_info "init: fertig"
}

# ============================================================
# task new / list / show / delete
# ============================================================

cmd_task_new() {
    _agent_require_task_id
    if ! task_id_validate "$ARG_TASK_ID"; then
        die "$EXIT_PRECONDITION" "Task-ID '$ARG_TASK_ID' ist invalide"
    fi
    if credentials_task_exists "$ARG_TASK_ID" || task_volume_exists "$ARG_TASK_ID"; then
        die "$EXIT_PRECONDITION" "Task '$ARG_TASK_ID' existiert bereits"
    fi

    if ! credentials_has_claude_token; then
        die "$EXIT_AUTH" "Bitte 'agent init' zuerst ausfuehren (Claude-Token fehlt)"
    fi

    printf 'REPO_URL (https://github.com/...): '
    local repo_url
    IFS= read -r repo_url
    [[ -n "$repo_url" ]] || die "$EXIT_GENERAL" "REPO_URL darf nicht leer sein"

    printf 'REPO_TOKEN (versteckt; ghp_... fuer GitHub PAT): '
    local repo_token
    IFS= read -rs repo_token
    printf '\n'
    [[ -n "$repo_token" ]] || die "$EXIT_GENERAL" "REPO_TOKEN darf nicht leer sein"

    printf 'BASE_BRANCH [main]: '
    local base_branch
    IFS= read -r base_branch
    base_branch="${base_branch:-main}"

    # Description in $EDITOR
    local editor="${EDITOR:-${VISUAL:-vi}}"
    local desc_tmp
    desc_tmp="$(mktemp /tmp/agent-desc-XXXXXX.md)"
    printf '# Task-Beschreibung fuer %s\n\n# Beschreibe die Aufgabe hier in Markdown.\n# Kommentar-Zeilen (mit "#") werden nicht entfernt — schreib unterhalb.\n\n' \
        "$ARG_TASK_ID" > "$desc_tmp"
    "$editor" "$desc_tmp"

    if [[ ! -s "$desc_tmp" ]]; then
        rm -f "$desc_tmp"
        die "$EXIT_GENERAL" "Description darf nicht leer sein"
    fi

    # Persistieren auf Host
    credentials_save_task "$ARG_TASK_ID" "$repo_url" "$repo_token" "$base_branch"
    local desc_dir
    desc_dir="$(_credentials_task_path "$ARG_TASK_ID")"
    mv "$desc_tmp" "$desc_dir/description.md"
    chmod 644 "$desc_dir/description.md"

    # Volume anlegen
    task_create_volume "$ARG_TASK_ID"
    log_info "task new: '$ARG_TASK_ID' angelegt (Volume + credentials.env + description.md)"
}

cmd_task_list() {
    local ids
    ids="$(task_list)"
    if [[ -z "$ids" ]]; then
        echo "Keine Tasks angelegt."
        return 0
    fi
    printf '%-30s %-10s %s\n' TASK_ID PHASE STATUS
    local id
    while IFS= read -r id; do
        [[ -z "$id" ]] && continue
        # Versuche state.json aus Volume zu lesen
        local status_summary="(volume only)"
        if credentials_task_exists "$id"; then
            status_summary="(host only)"
        fi
        if task_volume_exists "$id" && credentials_task_exists "$id"; then
            status_summary="ok"
        fi
        printf '%-30s %s\n' "$id" "$status_summary"
    done <<< "$ids"
}

cmd_task_show() {
    _agent_require_task_id
    _agent_require_known_task
    local file
    file="$(_credentials_task_path "$ARG_TASK_ID")/credentials.env"
    if [[ ! -f "$file" ]]; then
        die "$EXIT_PRECONDITION" "credentials.env fehlt"
    fi
    # Token wird hier NICHT ausgegeben
    local repo_url base_branch
    # shellcheck disable=SC1090
    ( source "$file"
      printf 'TASK_ID:     %s\n' "$ARG_TASK_ID"
      printf 'REPO_URL:    %s\n' "${REPO_URL:-?}"
      printf 'BASE_BRANCH: %s\n' "${BASE_BRANCH:-?}"
      printf 'REPO_TOKEN:  (verborgen, %d Zeichen)\n' "${#REPO_TOKEN}" )
    if task_volume_exists "$ARG_TASK_ID"; then
        printf 'Volume:      task_ws_%s (vorhanden)\n' "$ARG_TASK_ID"
    else
        printf 'Volume:      task_ws_%s (FEHLT)\n' "$ARG_TASK_ID"
    fi
    : "$repo_url" "$base_branch"
}

cmd_task_delete() {
    cmd_abort
}

# ============================================================
# concept / implement / diff / push
# ============================================================

cmd_phase() {
    local phase="$1"
    _agent_require_task_id
    _agent_require_known_task
    _agent_load_task_env "$ARG_TASK_ID"

    if ! task_volume_exists "$ARG_TASK_ID"; then
        die "$EXIT_PRECONDITION" "Volume task_ws_$ARG_TASK_ID fehlt"
    fi

    local flags_json
    case "$phase" in
        concept)
            flags_json="$(_agent_phase_flags_json fresh force-unlock)"
            ;;
        implement)
            flags_json="$(_agent_phase_flags_json fresh continue max-turns force-unlock)"
            if [[ -n "${ARG_FLAG_MAX_TURNS:-}" ]]; then
                MAX_TURNS="$ARG_FLAG_MAX_TURNS"
                export MAX_TURNS
            fi
            ;;
        diff)
            flags_json="$(_agent_phase_flags_json stat file)"
            ;;
        push)
            flags_json="$(_agent_phase_flags_json auto-cleanup keep force-unlock)"
            ;;
    esac
    PHASE_FLAGS="$flags_json"
    export PHASE_FLAGS

    log_info "running phase=$phase task=$ARG_TASK_ID flags=$flags_json"
    set +e
    docker_run_phase "$phase" "$ARG_TASK_ID"
    local rc=$?
    set -e

    # Push-spezifisch: Cleanup-Frage
    if [[ "$phase" == "push" && "$rc" -eq 0 ]]; then
        local auto="${ARG_FLAG_AUTO_CLEANUP:-}"
        local keep="${ARG_FLAG_KEEP:-}"
        if [[ "$auto" == "true" ]]; then
            cmd_abort_silent "$ARG_TASK_ID"
            log_info "push: --auto-cleanup → Volume und Host-State entfernt"
        elif [[ "$keep" != "true" ]]; then
            printf 'Push erfolgreich. Workspace+Host-State loeschen? [y/N] '
            local ans
            IFS= read -r ans || ans="n"
            if [[ "$ans" =~ ^[YyJj]$ ]]; then
                cmd_abort_silent "$ARG_TASK_ID"
                log_info "push: cleanup durchgefuehrt"
            fi
        fi
    fi

    return "$rc"
}

# ============================================================
# show / edit Konzept und Notes
# ============================================================

cmd_show_concept() {
    _agent_require_task_id
    _agent_require_known_task
    _agent_run_volume_cmd "$ARG_TASK_ID" 'cat /workspace/.agent/concept.md 2>/dev/null || echo "(noch kein concept.md — agent concept zuerst)"'
}

cmd_edit_concept() {
    _edit_volume_file "$ARG_TASK_ID" .agent/concept.md
}

cmd_show_notes() {
    _agent_require_task_id
    _agent_require_known_task
    _agent_run_volume_cmd "$ARG_TASK_ID" 'cat /workspace/.agent/concept.notes.md 2>/dev/null || echo "(keine concept.notes.md — agent edit-notes zum Anlegen)"'
}

cmd_edit_notes() {
    _edit_volume_file "$ARG_TASK_ID" .agent/concept.notes.md
}

# _edit_volume_file: Editor-Integration (Copy-In/Copy-Out + Hash-Check).
# Args: $1=task_id, $2=in-volume-pfad (relativ zu /workspace)
_edit_volume_file() {
    local task_id="$1"
    local rel="$2"
    [[ -z "$task_id" ]] && die "$EXIT_PRECONDITION" "task-id fehlt"
    if ! credentials_task_exists "$task_id"; then
        die "$EXIT_PRECONDITION" "Task '$task_id' nicht bekannt"
    fi

    local editor="${EDITOR:-${VISUAL:-vi}}"
    local tmp
    tmp="$(mktemp /tmp/agent-edit-XXXXXX.md)"

    # Copy in (falls Datei existiert)
    docker_copy_from_volume "$task_id" "$rel" "$tmp" 2>/dev/null || : > "$tmp"

    local hash_before
    hash_before="$(sha256sum "$tmp" | cut -d' ' -f1)"

    "$editor" "$tmp"

    local hash_after
    hash_after="$(sha256sum "$tmp" | cut -d' ' -f1)"

    if [[ "$hash_before" == "$hash_after" ]]; then
        log_info "edit: keine Aenderungen, breche ab"
        rm -f "$tmp"
        return 0
    fi

    docker_copy_to_volume "$task_id" "$tmp" "$rel"
    rm -f "$tmp"
    log_info "edit: $rel zurueckgeschrieben"
}

# ============================================================
# logs / shell / status / abort / prune
# ============================================================

cmd_logs() {
    _agent_require_task_id
    _agent_require_known_task
    local phase_filter="${ARG_FLAG_PHASE:-}"
    local iter_filter="${ARG_FLAG_ITERATION:-}"
    local find_expr="-name '*.log'"
    if [[ -n "$phase_filter" ]]; then
        find_expr="-name '${phase_filter}.*'"
    fi
    local cmd="ls /workspace/.agent/logs 2>/dev/null"
    if [[ -n "$phase_filter" && -n "$iter_filter" ]]; then
        cmd="cat /workspace/.agent/logs/${phase_filter}.${iter_filter}.* 2>/dev/null || echo '(keine logs fuer diese kombination)'"
    elif [[ -n "$phase_filter" ]]; then
        cmd="ls /workspace/.agent/logs/${phase_filter}.* 2>/dev/null || echo '(keine logs)'"
    fi
    _agent_run_volume_cmd "$ARG_TASK_ID" "$cmd"
    : "$find_expr"
}

cmd_shell() {
    _agent_require_task_id
    _agent_require_known_task
    _agent_load_task_env "$ARG_TASK_ID"
    docker_run_shell "$ARG_TASK_ID"
}

cmd_status() {
    if [[ -z "$ARG_TASK_ID" ]]; then
        cmd_task_list
        return
    fi
    _agent_require_known_task

    local state_json
    state_json="$(_agent_run_volume_cmd "$ARG_TASK_ID" \
        'jq -c . /workspace/.agent/state.json 2>/dev/null')" || true

    if [[ -z "$state_json" ]]; then
        printf 'Task:   %s\n' "$ARG_TASK_ID"
        printf 'Status: (noch keine state.json — erst concept ausfuehren)\n'
        return 0
    fi

    local repo_url base_branch feature_branch created_at
    repo_url="$(jq -r '.repo.url // "?"' <<< "$state_json")"
    base_branch="$(jq -r '.repo.base_branch // "?"' <<< "$state_json")"
    feature_branch="$(jq -r '.repo.feature_branch // "-"' <<< "$state_json")"
    created_at="$(jq -r '.created_at // "?"' <<< "$state_json")"

    printf '\033[1mTask:          %s\033[0m\n' "$ARG_TASK_ID"
    printf 'Repo:          %s\n' "$repo_url"
    printf 'Base-Branch:   %s\n' "$base_branch"
    printf 'Feature-Branch:%s\n' "$feature_branch"
    printf 'Erstellt:      %s\n' "$created_at"
    printf '\n'

    local status_icon
    for phase in concept implement diff push; do
        local current_status iter_count
        current_status="$(jq -r --arg p "$phase" '.phases[$p].current_status // "pending"' <<< "$state_json")"
        iter_count="$(jq -r --arg p "$phase" '(.phases[$p].iterations // []) | length' <<< "$state_json")"

        case "$current_status" in
            completed)           status_icon='✓' ;;
            running)             status_icon='⟳' ;;
            failed)              status_icon='✗' ;;
            quality_gate_failed) status_icon='✗' ;;
            no_changes)          status_icon='—' ;;
            *)                   status_icon='·' ;;
        esac

        printf '  %s %-12s  %s' "$status_icon" "$phase" "$current_status"
        if [[ "$iter_count" -gt 0 ]]; then
            printf '  (%s Iteration(en))' "$iter_count"
        fi
        printf '\n'

        # Iterationen ausgeben wenn vorhanden
        if [[ "$iter_count" -gt 0 ]]; then
            local iter_list
            iter_list="$(jq -r --arg p "$phase" \
                '.phases[$p].iterations[] | "     #\(.n)  \(.status)  \(.started_at[0:16] // "?")  \(if .finished_at then .finished_at[0:16] else "-" end)\(if .failed_gate then "  gate:\(.failed_gate)" else "" end)\(if .error_message then "  err:\(.error_message[0:60])" else "" end)"' \
                <<< "$state_json" 2>/dev/null)"
            [[ -n "$iter_list" ]] && printf '%s\n' "$iter_list"
        fi
    done
}

# cmd_abort_silent: Loescht Volume + Host-State ohne Frage. Helper fuer push --auto-cleanup.
cmd_abort_silent() {
    local task_id="$1"
    task_delete_volume "$task_id"
    credentials_delete_task "$task_id"
}

cmd_abort() {
    _agent_require_task_id
    if ! credentials_task_exists "$ARG_TASK_ID" && ! task_volume_exists "$ARG_TASK_ID"; then
        log_info "abort: Task '$ARG_TASK_ID' bereits weg"
        return 0
    fi
    printf 'Volume + ~/.agent/tasks/%s endgueltig loeschen? [y/N] ' "$ARG_TASK_ID"
    local ans
    IFS= read -r ans || ans="n"
    if [[ ! "$ans" =~ ^[YyJj]$ ]]; then
        log_info "abort: abgebrochen"
        return 0
    fi
    cmd_abort_silent "$ARG_TASK_ID"
    log_info "abort: '$ARG_TASK_ID' entfernt"
}

cmd_prune() {
    local orphans
    orphans="$(task_orphans)"
    if [[ -z "$orphans" ]]; then
        log_info "prune: keine verwaisten Volumes"
        return 0
    fi
    echo "Verwaiste Volumes (kein Host-State unter ~/.agent/tasks/):"
    echo "$orphans"
    printf 'Alle loeschen? [y/N] '
    local ans
    IFS= read -r ans || ans="n"
    if [[ ! "$ans" =~ ^[YyJj]$ ]]; then
        log_info "prune: abgebrochen"
        return 0
    fi
    local id
    while IFS= read -r id; do
        [[ -z "$id" ]] && continue
        task_delete_volume "$id"
        log_info "prune: $id geloescht"
    done <<< "$orphans"
}

# ============================================================
# Dispatcher
# ============================================================

main() {
    parse_args "$@"

    case "$ARG_COMMAND" in
        ""|help|--help|-h)
            help_show "$ARG_TASK_ID"
            ;;
        init)
            cmd_init
            ;;
        task)
            case "$ARG_SUBCOMMAND" in
                new)    cmd_task_new ;;
                list)   cmd_task_list ;;
                show)   cmd_task_show ;;
                delete) cmd_task_delete ;;
                "")     help_task ;;
                *)      die "$EXIT_GENERAL" "Unbekanntes task-Subcommand '$ARG_SUBCOMMAND' (siehe agent help task)" ;;
            esac
            ;;
        concept|implement|diff|push)
            cmd_phase "$ARG_COMMAND"
            ;;
        show-concept)  cmd_show_concept ;;
        edit-concept)  cmd_edit_concept ;;
        show-notes)    cmd_show_notes ;;
        edit-notes)    cmd_edit_notes ;;
        logs)          cmd_logs ;;
        shell)         cmd_shell ;;
        status)        cmd_status ;;
        abort)         cmd_abort ;;
        prune)         cmd_prune ;;
        *)
            die "$EXIT_GENERAL" "Unbekanntes Command '$ARG_COMMAND' (siehe agent help)"
            ;;
    esac
}

main "$@"
