{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/boost-freshness-check.sh"
          },
          {
            "type": "command",
            "command": ".claude/scripts/retro-reminder.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(.claude/scripts/*)",
      "Bash(./vendor/bin/pest*)",
      "Bash(./vendor/bin/phpstan*)",
      "Bash(./vendor/bin/pint*)",
      "Bash(bash worker/tests/run-bats.sh)",
      "Bash(bash worker/tests/run-tests.sh)",
      "Bash(bats worker/tests/*)",
      "Bash(cat *)",
      "Bash(composer dump-autoload*)",
      "Bash(composer fund*)",
      "Bash(composer install*)",
      "Bash(composer list*)",
      "Bash(composer outdated*)",
      "Bash(composer pint*)",
      "Bash(composer phpstan*)",
      "Bash(composer qa*)",
      "Bash(composer show*)",
      "Bash(composer test*)",
      "Bash(composer validate*)",
      "Bash(composer why*)",
      "Bash(docker compose -f .tools/docker/docker-compose.yml logs*)",
      "Bash(docker compose -f .tools/docker/docker-compose.yml ps*)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(git branch)",
      "Bash(git branch --list*)",
      "Bash(git branch -v*)",
      "Bash(git check-ignore*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git ls-files*)",
      "Bash(git rev-parse*)",
      "Bash(git show*)",
      "Bash(git stash list*)",
      "Bash(git status*)",
      "Bash(grep *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(npx playwright test*)",
      "Bash(php -v)",
      "Bash(php artisan --version)",
      "Bash(php artisan boost:install*)",
      "Bash(php artisan config:show*)",
      "Bash(php artisan db:show*)",
      "Bash(php artisan db:table*)",
      "Bash(php artisan list)",
      "Bash(php artisan migrate:status)",
      "Bash(php artisan package:discover*)",
      "Bash(php artisan route:list*)",
      "Bash(php artisan test*)",
      "Bash(rg *)",
      "Bash(shellcheck*)",
      "Bash(stat *)",
      "Bash(wc *)"
    ]
  }
}
