APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_LIFETIME=120

# CACHE_PREFIX=

VITE_APP_NAME="${APP_NAME}"

# Argos
ADMIN_PASSWORD=12345
CLAUDE_CODE_OAUTH_TOKEN=
ARGOS_WORKER_IMAGE=argos-worker:local-php8.4

# GitHub OAuth (optional — enables repo/branch dropdown in project config)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI="${APP_URL}/auth/github/callback"
# ARGOS_CONFIG_DIR=/data/config
# ARGOS_MEM_LIMIT=4g
# ARGOS_CPU_LIMIT=2

# MariaDB sidecar (docker compose --profile db up).
# Without these vars the app falls back to SQLite.
# ARGOS_DB_HOST=db
# ARGOS_DB_PORT=3306
# ARGOS_DB_DATABASE=argos
# ARGOS_DB_USERNAME=argos
# ARGOS_DB_PASSWORD=argos
# MARIADB_ROOT_PASSWORD=argos-root
