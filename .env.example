# Argos environment variables.
#
# This file is the canonical menu of every variable Argos understands. All
# entries are commented out — uncomment only what you want to override. The
# stage script (.tools/bash/start-stage.sh) copies this file into a
# fully-commented .env.stage on first run, so the same template works for
# local dev and stage deployments.

# ── Core ─────────────────────────────────────────────────────────────────────
# APP_NAME=Argos
# APP_ENV=local                      # local | staging | production
# APP_KEY=                            # auto-generated on first manager boot
# APP_DEBUG=true
# APP_URL=http://localhost
# APP_LOCALE=en                       # en | de
# APP_PREVIOUS_KEYS=                  # comma-separated, for APP_KEY rotation

# LOG_LEVEL=debug

# ── Database ─────────────────────────────────────────────────────────────────
# DB_CONNECTION=sqlite                # sqlite | mariadb
# DB_DATABASE=/path/to/argos.sqlite

# ── Sessions ─────────────────────────────────────────────────────────────────
# SESSION_DOMAIN=                     # set for cross-subdomain cookies
# SESSION_SECURE_COOKIE=              # force-set when behind HTTPS proxy

# ── Argos ────────────────────────────────────────────────────────────────────
# ADMIN_PASSWORD=12345
# CLAUDE_CODE_OAUTH_TOKEN=
# ARGOS_WORKER_IMAGE=argos-worker:local-php8.4
# ARGOS_CONFIG_DIR=/data/config
# ARGOS_MEM_LIMIT=4g
# ARGOS_CPU_LIMIT=2
# ARGOS_MAX_TURNS_DEFAULT=200

# ── GitHub OAuth (optional — enables repo/branch dropdown) ────────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ── GitLab OAuth (optional) ──────────────────────────────────────────────────
# GITLAB_CLIENT_ID=
# GITLAB_CLIENT_SECRET=
# GITLAB_INSTANCE_URL=https://gitlab.com   # override for self-hosted GitLab

# ── Bitbucket OAuth (optional) ───────────────────────────────────────────────
# BITBUCKET_CLIENT_ID=
# BITBUCKET_CLIENT_SECRET=

# ── MariaDB sidecar (docker compose --profile db up) ─────────────────────────
# Without these vars the app falls back to SQLite.
# ARGOS_DB_HOST=db
# ARGOS_DB_PORT=3306
# ARGOS_DB_DATABASE=argos
# ARGOS_DB_USERNAME=argos
# ARGOS_DB_PASSWORD=argos
# ARGOS_DB_SOCKET=/run/mysqld/mysqld.sock   # Unix socket, in-container MariaDB
# ARGOS_DB_SSL_CA=/path/to/ca.pem           # optional TLS CA bundle
# ARGOS_DB_URL=                              # full DSN, overrides individual fields
