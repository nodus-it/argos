# Argos environment variables (development / contributor template).
#
# This file is the canonical menu of every variable the Laravel app reads.
# All entries are commented out — uncomment only what you want to override.
# The stage script (.tools/bash/start-stage.sh) copies this file into a
# fully-commented .env.stage on first run.
#
# Self-host operators don't write this file by hand: install.sh ships its
# own installer/.env.example with the OPS-level keys (ports, image tags,
# generated secrets) and writes a populated .env into the install directory.

# ── Core ─────────────────────────────────────────────────────────────────────
# APP_NAME=Argos
# APP_ENV=local                      # local | staging | production
# APP_KEY=                            # auto-generated on first manager boot
# APP_DEBUG=true
# APP_URL=http://localhost
# APP_LOCALE=en                       # en | de
# APP_PREVIOUS_KEYS=                  # comma-separated, for APP_KEY rotation

# LOG_LEVEL=debug

# ── Database ─────────────────────────────────────────────────────────────────
# DB_CONNECTION=sqlite                # sqlite | mariadb
# DB_DATABASE=/path/to/argos.sqlite

# ── Sessions ─────────────────────────────────────────────────────────────────
# SESSION_DOMAIN=                     # set for cross-subdomain cookies
# SESSION_SECURE_COOKIE=              # force-set when behind HTTPS proxy

# ── Argos ────────────────────────────────────────────────────────────────────
# ADMIN_PASSWORD=12345
# CLAUDE_CODE_OAUTH_TOKEN=
# ARGOS_WORKER_IMAGE=argos-worker:local-php8.4
# ARGOS_CONFIG_DIR=/data/config
# ARGOS_MEM_LIMIT=4g
# ARGOS_CPU_LIMIT=2
# ARGOS_MAX_TURNS_DEFAULT=200
# ARGOS_SOURCE_URL=https://github.com/nodus-it/argos   # AGPL §13: forks must point this at their own source

# ── MCP (optional) ───────────────────────────────────────────────────────────
# Enable the target project's Laravel Boost MCP server for Claude sessions.
# When set to true and the target project's boost.json has "mcp": true, the
# worker configures Claude to start `php artisan boost:mcp` as a local stdio
# subprocess inside the worker container — no network access required.
# ARGOS_MCP_ENABLED=true

# ── GitHub OAuth (optional — enables repo/branch dropdown) ────────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ── GitLab OAuth (optional) ──────────────────────────────────────────────────
# GITLAB_CLIENT_ID=
# GITLAB_CLIENT_SECRET=
# GITLAB_INSTANCE_URL=https://gitlab.com   # override for self-hosted GitLab

# ── Bitbucket OAuth (optional) ───────────────────────────────────────────────
# BITBUCKET_CLIENT_ID=
# BITBUCKET_CLIENT_SECRET=

# ── MariaDB ──────────────────────────────────────────────────────────────────
# The compose stack provides a `db` service over TCP. Set DB_CONNECTION=mariadb
# to use it, or leave it on `sqlite` (the Laravel default) to run against a
# local file.
# ARGOS_DB_HOST=db
# ARGOS_DB_PORT=3306
# ARGOS_DB_DATABASE=argos
# ARGOS_DB_USERNAME=argos
# ARGOS_DB_PASSWORD=argos
# ARGOS_DB_SSL_CA=/path/to/ca.pem    # optional TLS CA bundle
# ARGOS_DB_URL=                       # full DSN, overrides individual fields
