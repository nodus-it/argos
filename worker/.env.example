# Claude Worker — Beispiel-Konfiguration
#
# Kopieren nach `.env` und nach Bedarf anpassen, oder Variablen direkt
# beim `docker compose run`-Aufruf setzen. Die `agent`-CLI uebergibt die
# pro-Task-Werte (REPO_URL, REPO_TOKEN, ...) ohnehin direkt aus
# ~/.agent/tasks/<task-id>/credentials.env.

# Resource-Limits (Defaults: 4 GB RAM, 2 CPUs)
AGENT_MEM_LIMIT=4g
AGENT_CPU_LIMIT=2

# Werden vom agent-CLI pro Task gesetzt — hier nur als Platzhalter.
PHASE=
TASK_ID=
REPO_URL=
REPO_TOKEN=
BASE_BRANCH=
CLAUDE_CODE_OAUTH_TOKEN=
PHASE_FLAGS=
MAX_TURNS=
