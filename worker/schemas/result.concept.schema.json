{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Concept Phase Result",
  "type": "object",
  "required": ["phase", "task_id", "iteration", "status", "started_at", "finished_at", "exit_code"],
  "properties": {
    "phase": {"const": "concept"},
    "task_id": {"type": "string"},
    "iteration": {"type": "integer", "minimum": 1},
    "status": {
      "type": "string",
      "enum": ["completed", "failed"]
    },
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"},
    "duration_ms": {"type": "integer"},
    "exit_code": {"type": "integer"},
    "concept_path": {"type": "string"},
    "concept_history_count": {"type": "integer", "minimum": 0},
    "claude_session_id": {"type": ["string", "null"]},
    "claude_total_cost_usd": {"type": ["number", "null"]},
    "error_message": {"type": ["string", "null"]}
  }
}
