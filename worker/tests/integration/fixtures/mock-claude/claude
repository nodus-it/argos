#!/usr/bin/env bash
# tests/integration/fixtures/mock-claude/claude — deterministisches Claude-Mock.
#
# Wird per Bind-Mount im Worker-Container als /usr/bin/claude eingehängt
# (siehe tests/integration/docker-compose.test.yml) und ersetzt damit das
# echte Claude Code CLI. Liest stdin, prüft auf Phasen-Marker im User-Prompt,
# liefert deterministische JSON-/stream-json-Antworten.
#
# Marker: "Konzept-Aufgabe" → concept, "Implement-Phase" → implement,
# "Commit-Message generieren" → commit-message.
#
# MOCK_CLAUDE_ERROR_MODE überschreibt alle Phase-Antworten fuer Fehlerszenarien:
#   rate_limit   — is_error=true, "rate limit exceeded"
#   auth_error   — is_error=true, "invalid api key — 401 unauthorized"
#   empty_result — is_error=false, result=""
#   invalid_json — gibt kein valides JSON aus
set -euo pipefail
IFS=$'\n\t'

output_format=text
while [[ $# -gt 0 ]]; do
    case "$1" in
        -p|--print|--include-partial-messages|--verbose|--bare)
            shift ;;
        --output-format)            output_format="${2:-text}"; shift 2 ;;
        --json-schema)              shift 2 ;;
        --append-system-prompt)     shift 2 ;;
        --max-turns)                shift 2 ;;
        --permission-mode)          shift 2 ;;
        --version)                  echo "mock-claude (test fixture)"; exit 0 ;;
        --help|-h)                  echo "mock-claude — test fixture"; exit 0 ;;
        *)                          shift ;;
    esac
done

stdin="$(cat)"

# Error-Modus überschreibt normale Phase-Antworten.
if [[ -n "${MOCK_CLAUDE_ERROR_MODE:-}" ]]; then
    case "$MOCK_CLAUDE_ERROR_MODE" in
        rate_limit)
            printf '{"type":"result","subtype":"error","is_error":true,"result":"rate limit exceeded — please retry later","session_id":"mock-err","total_cost_usd":0}\n'
            ;;
        auth_error)
            printf '{"type":"result","subtype":"error","is_error":true,"result":"invalid api key — 401 unauthorized","session_id":"mock-err","total_cost_usd":0}\n'
            ;;
        empty_result)
            printf '{"type":"result","subtype":"success","is_error":false,"result":"","session_id":"mock-err","total_cost_usd":0}\n'
            ;;
        invalid_json)
            printf 'NOT VALID JSON\n'
            ;;
    esac
    exit 0
fi

mode=unknown
if [[ "$stdin" == *"Konzept-Aufgabe"* ]]; then mode=concept
elif [[ "$stdin" == *"Implement-Phase"* ]]; then mode=implement
elif [[ "$stdin" == *"Commit-Message generieren"* ]]; then mode=commit-message
elif [[ "$stdin" == *"Respond-Phase"* ]]; then mode=respond
fi

case "$mode:$output_format" in
    concept:stream-json)
        printf '{"type":"system","subtype":"init","session_id":"mock-concept-1"}\n'
        printf '{"type":"assistant","message":{"content":[{"type":"text","text":"Konzept wird erstellt..."}]}}\n'
        printf '{"type":"result","subtype":"success","is_error":false,"result":"# Konzept: Mock HelloWorld\\n\\n## Verstaendnis der Aufgabe\\n\\nDemo-Aufgabe - eine HelloWorld-Klasse anlegen.\\n\\n## Geplante Aenderungen\\n\\n- app/Demo/HelloWorld.php (neu): Klasse mit Methode greet()\\n- tests/Feature/Demo/HelloWorldTest.php (neu): Pest-Test fuer greet()\\n\\n## Vorgehensweise\\n\\n1. Klasse anlegen.\\n2. Test schreiben.\\n","session_id":"mock-concept-1","total_cost_usd":0.001,"num_turns":1}\n'
        ;;
    implement:stream-json)
        # Mock simuliert "Code-Aenderung" indem es Files in /workspace anlegt.
        if [[ -d /workspace ]]; then
            mkdir -p /workspace/app/Demo /workspace/tests/Feature/Demo
            cat > /workspace/app/Demo/HelloWorld.php <<'PHP'
<?php
declare(strict_types=1);
namespace App\Demo;
final class HelloWorld
{
    public function greet(string $name): string
    {
        return "Hello, $name!";
    }
}
PHP
            cat > /workspace/tests/Feature/Demo/HelloWorldTest.php <<'PHP'
<?php
declare(strict_types=1);
test('greet returns Hello, $name', function () {
    expect((new App\Demo\HelloWorld())->greet('World'))->toBe('Hello, World!');
});
PHP
        fi
        # Stream-JSON: mehrere events, dann ein result event
        printf '{"type":"system","subtype":"init","session_id":"mock-impl-1"}\n'
        printf '{"type":"assistant","content":"Lege HelloWorld an"}\n'
        printf '{"type":"result","subtype":"success","is_error":false,"result":"Done","session_id":"mock-impl-1","total_cost_usd":0.005,"num_turns":3}\n'
        ;;
    commit-message:json)
        cat <<'EOF'
{"type":"result","subtype":"success","is_error":false,"result":"{\"subject\":\"feat: add HelloWorld greeter\",\"body\":\"Adds App\\\\Demo\\\\HelloWorld with greet() method and Pest test.\"}","structured_output":{"subject":"feat: add HelloWorld greeter","body":"Adds App\\Demo\\HelloWorld with greet() method and Pest test."},"session_id":"mock-cm-1","total_cost_usd":0.001,"num_turns":1}
EOF
        ;;
    respond:stream-json)
        printf '{"type":"system","subtype":"init","session_id":"mock-respond-1"}\n'
        printf '{"type":"assistant","message":{"content":[{"type":"text","text":"Feedback wird eingearbeitet..."}]}}\n'
        printf '{"type":"result","subtype":"success","is_error":false,"result":"Feedback eingearbeitet.","session_id":"mock-respond-1","total_cost_usd":0.002,"num_turns":2}\n'
        ;;
    *:*)
        printf '{"type":"result","subtype":"error","is_error":true,"result":"mock-claude: unknown prompt mode (mode=%s output=%s)","session_id":"mock-x","total_cost_usd":0}\n' "$mode" "$output_format" >&2
        exit 1
        ;;
esac
